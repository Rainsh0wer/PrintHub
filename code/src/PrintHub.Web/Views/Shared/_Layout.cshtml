@using PrintHub.Web.Services
@{
    var role = Context.Session.GetString(SessionKeys.UserRole);
    var name = Context.Session.GetString(SessionKeys.UserName);
    var signedIn = !string.IsNullOrEmpty(Context.Session.GetString(SessionKeys.AccessToken));
    var isShop = role is "ShopOwner" or "ShopStaff";
    string Active(string c) => (ViewContext.RouteData.Values["controller"]?.ToString() == c) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " · PrintHub" : "PrintHub — Print & Fabrication Marketplace")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800;900&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/printhub.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <div class="wrap">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="regmark cmyk"></span> PrintHub
            </a>
            <nav class="nav">
                <a class="@Active("Shops")" asp-controller="Shops" asp-action="Index">Shops</a>
                @if (signedIn && role == "Customer")
                {
                    <a class="@Active("Quotes")" asp-controller="Quotes" asp-action="Index">Compare</a>
                    <a class="@Active("Orders")" asp-controller="Orders" asp-action="Index">Orders</a>
                    <a class="@Active("Wallet") hide-sm" asp-controller="Wallet" asp-action="Index">Wallet</a>
                }
                @if (isShop)
                {
                    <a class="hide-sm" href="#">Shop console</a>
                }
                @if (signedIn)
                {
                    <span class="who">@name · @role</span>
                    <a asp-controller="Account" asp-action="Logout">Sign out</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                    <a class="btn accent sm" asp-controller="Account" asp-action="Register">Get started</a>
                }
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="foot">
        <div class="wrap between">
            <div class="stack" style="--gap:.4rem">
                <span class="brand" style="font-size:1rem"><span class="regmark"></span> PrintHub</span>
                <span class="muted">A marketplace for print &amp; fabrication shops.</span>
            </div>
            <div class="eyebrow">PRN232 · Built on ASP.NET Core</div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
