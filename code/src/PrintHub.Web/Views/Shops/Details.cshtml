@model PrintHub.Application.Features.Shops.Dtos.ShopDetailDto
@{
    ViewData["Title"] = Model?.Name ?? "Shop";
}

@if (Model is null)
{
    <div class="wrap" style="padding:80px 0"><div class="alert err">@ViewBag.Error</div></div>
    return;
}

<section class="wrap" style="padding-top:36px;padding-bottom:80px">
    <a class="eyebrow" asp-action="Index" style="margin-bottom:20px">← Back to shops</a>

    <div class="between" style="align-items:flex-start;margin:18px 0 28px">
        <div class="stack" style="--gap:.5rem">
            <h1 style="font-size:2.6rem">@Model.Name</h1>
            <div class="mono muted">@Model.AddressLine · @Model.District, @Model.City</div>
            <div class="row" style="gap:1.2rem;align-items:center;margin-top:.4rem">
                <span class="rating" style="font-size:1.05rem">★ @Model.RatingAverage.ToString("0.0")</span>
                <span class="muted mono" style="font-size:.82rem">@Model.RatingCount reviews</span>
                <span class="badge"><span class="dot ok"></span> @Model.OpenTime.ToString("HH:mm")–@Model.CloseTime.ToString("HH:mm")</span>
            </div>
        </div>
        <a class="btn accent" asp-controller="Quotes" asp-action="Index" asp-route-shopId="@Model.Id">Get a quote</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="lede" style="max-width:60ch;margin-bottom:36px">@Model.Description</p>
    }

    <div class="grid" style="grid-template-columns:1.4fr .9fr;align-items:start">
        <div class="card">
            <div class="pad">
                <div class="eyebrow" style="margin-bottom:14px">Rate card</div>
                <table class="tbl">
                    <thead><tr><th>Service</th><th>Group</th><th>Lead</th><th style="text-align:right">Unit price</th></tr></thead>
                    <tbody>
                        @foreach (var svc in Model.Services)
                        {
                            <tr>
                                <td><strong>@svc.ServiceTypeName</strong></td>
                                <td><span class="badge">@svc.ServiceGroup</span></td>
                                <td class="mono muted">@svc.LeadTimeMinutes min</td>
                                <td style="text-align:right"><span class="price">@svc.UnitPrice.ToString("N0")<span class="cur">₫</span></span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="stack" style="--gap:20px">
            <div class="card"><div class="pad">
                <div class="eyebrow" style="margin-bottom:12px">Equipment</div>
                <div class="tag-list">
                    @foreach (var m in Model.Machines)
                    {
                        var cls = m.Status == "Idle" ? "ok" : (m.Status == "Offline" ? "err" : "warn");
                        <span class="badge"><span class="dot @cls"></span> @m.Name</span>
                    }
                </div>
            </div></div>

            <div class="card"><div class="pad stack" style="--gap:14px">
                <div class="eyebrow">Recent reviews</div>
                @if (!Model.Reviews.Any())
                {
                    <p class="muted" style="margin:0;font-size:.9rem">No reviews yet.</p>
                }
                @foreach (var r in Model.Reviews.Take(4))
                {
                    <div class="stack" style="--gap:.3rem">
                        <div class="between">
                            <strong style="font-size:.92rem">@r.CustomerName</strong>
                            <span class="rating">★ @r.Rating</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(r.Comment))
                        {
                            <p class="muted" style="margin:0;font-size:.88rem">@r.Comment</p>
                        }
                    </div>
                    <hr class="divider">
                }
            </div></div>
        </div>
    </div>
</section>
